# =============================================================================
# Cyber Agent Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# For Ollama (local), no API key is needed - just set PROVIDER=ollama

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Provider selection: openai | anthropic | ollama | openrouter | groq | together | vllm
CYBER_AGENT_PROVIDER=ollama

# -----------------------------------------------------------------------------
# OpenAI (requires API key)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
CYBER_AGENT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Anthropic (requires API key)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Ollama (local, NO API key needed)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama  # placeholder, not used
# CYBER_AGENT_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# OpenRouter (requires API key)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# CYBER_AGENT_MODEL=openai/gpt-4o

# -----------------------------------------------------------------------------
# Groq (requires API key)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# CYBER_AGENT_MODEL=llama-3.1-70b-versatile

# -----------------------------------------------------------------------------
# Together AI (requires API key)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=together
# TOGETHER_API_KEY=your_together_api_key_here
# CYBER_AGENT_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

# -----------------------------------------------------------------------------
# vLLM (local or self-hosted, no real API key needed)
# -----------------------------------------------------------------------------
# CYBER_AGENT_PROVIDER=vllm
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=vllm  # placeholder
# CYBER_AGENT_MODEL=meta-llama/Llama-3.1-8B-Instruct

# =============================================================================
# WEB SEARCH & OSINT APIs (Optional but recommended)
# =============================================================================

# Tavily API for reliable web search (free tier available)
# Get key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Shodan API for internet device search (free tier available)
# Get key at: https://www.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# SecurityTrails API for DNS records (free tier available)
# Get key at: https://securitytrails.com/
SECURITY_TRAILS_API_KEY=your_securitytrails_api_key_here

# =============================================================================
# BOT TOKENS (Optional - for Telegram/Discord surfaces)
# =============================================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_ALLOWED_GUILDS=123456789012345678,987654321098765432

# =============================================================================
# NEO4J GRAPH DATABASE (Optional - for persistent world memory)
# =============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Engagement ID (optional - auto-generated from RoE if not set)
ENGAGEMENT_ID=

# Debug mode (set to 1 for verbose logging)
DEBUG=0
