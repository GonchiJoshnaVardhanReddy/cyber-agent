# LLM provider configuration
# Choose one: openai | anthropic | ollama | openrouter | nous
CYBER_AGENT_PROVIDER=openai

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
CYBER_AGENT_MODEL=gpt-4o

# Anthropic (used if CYBER_AGENT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local, no API key needed)
# CYBER_AGENT_PROVIDER=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# CYBER_AGENT_MODEL=llama3.1:70b

# OpenRouter
# CYBER_AGENT_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# CYBER_AGENT_MODEL=anthropic/claude-3.5-sonnet

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=

# Discord bot (optional)
DISCORD_BOT_TOKEN=

# Optional: web search (DuckDuckGo works without a key; for Brave/Serper add keys here)
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
