```gitignore
# Python compiled files
*.pyc
__pycache__/

# Dependency directories
.venv/
venv/
node_modules/

# Logs and temporary files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Build artifacts
dist/
build/
target/
.mypy_cache/
.pytest_cache/
```